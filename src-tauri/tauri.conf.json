{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zectrix Desktop",
  "version": "0.2.1",
  "identifier": "com.huang.zectrix-desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zectrix Desktop",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1280,
        "height": 860
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
